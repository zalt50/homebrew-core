                         &authpriv, NULL, 0,
-                        testctx, NULL))
-                    != 1) {
+                        testctx, NULL))) {
                     overallresult = 0;
                 }
                 authpubp = authpub;
@@ -1195,7 +1194,7 @@ static int test_hpke_suite_strs(void)
             for (aeadind = 0; aeadind != OSSL_NELEM(aead_str_list); aeadind++) {
